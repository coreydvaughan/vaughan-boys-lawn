---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Our Services | Vaughan Boys Outdoor Company">
	<section class="section">
		<div class="container section__grid">
			<div class="section__content">
				<h1 class="animate-in">Our Services</h1>

				<p>
					We offer reliable, hardworking help for your yard and around your home. Whether it's regular lawn
					maintenance or a one-time job, we're ready to help.
				</p>
			</div>

			<div class="section__media">
				<div class="services-grid">
					<div class="service-card">
						<h3>Core Lawn Services</h3>
						<ul>
							<li>Lawn mowing</li>
							<li>Edging</li>
							<li>Weed removal</li>
							<li>Raking leaves</li>
							<li>Yard cleanup</li>
							<li>Trash and debris pickup</li>
						</ul>
					</div>

					<div class="service-card">
						<h3>Additional Services</h3>
						<ul>
							<li>Washing trash cans</li>
							<li>Window cleaning</li>
							<li>Car washing</li>
							<li>General outdoor cleanup</li>
							<li>Small household and outdoor tasks</li>
						</ul>
					</div>
				</div>

				<p class="services-helper">
					We're also available to help with larger projects as extra hands. Whether you need a helper for a day
					or ongoing support, we're willing to learn, work hard, and get the job done.
				</p>

				<p class="services-cta">If you need something done, just ask—no job is too small.</p>
			</div>
		</div>
	</section>
</BaseLayout>
