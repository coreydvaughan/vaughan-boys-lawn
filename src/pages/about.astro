---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About Us | Vaughan Boys Outdoor Company">
	<section class="section">
		<div class="container section__grid">
			<div class="section__content">
				<h1 class="animate-in">About Us</h1>
				<p>
					Bruce and Cash Vaughan are two young entrepreneurs based in Lawton, Oklahoma. They attend Eisenhower
					Middle School, where they are active in football, track, and cross country, consistently pushing
					themselves to improve and succeed.
				</p>

				<p>
					Outside of school and sports, they enjoy fishing and spending time with friends and family. That same
					energy and discipline carries into their work.
				</p>

				<p>
					Vaughan Boys Outdoor Company was built on hard work, reliability, and a commitment to doing things the
					right way. They take pride in showing up on time, working efficiently, and making sure every lawn looks
					clean and well maintained.
				</p>

				<p>
					They are fast learners, highly motivated, and dedicated to earning your trust—no job is too small.
				</p>
			</div>

			<div class="section__media">
				<img src="/img/Boys.png" alt="Vaughan Boys Outdoor Company owners" class="about-image" />
			</div>
		</div>
	</section>
</BaseLayout>
