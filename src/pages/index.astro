---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="page-hero">
    <div class="page-hero__video" aria-hidden="true">
      <video
        autoplay
        muted
        loop
        playsinline
        webkit-playsinline
        preload="auto"
        class="hero-video"
      >
        <source src="/img/Hero-new.mp4" type="video/mp4" />
      </video>
    </div>

    <div class="page-hero__scrim" aria-hidden="true"></div>

    <div class="page-hero__inner">
      <h1 class="hero-animate hero-animate--1">Vaughan Boys Outdoor Company</h1>
      <p class="page-hero__tagline hero-animate hero-animate--2">
        Young, driven, and serious about doing it right—reliable lawn care you can count on.
      </p>

      <div class="btn-row page-hero__actions hero-animate hero-animate--3">
        <a class="btn btn--primary" href="tel:+12147272404">Call for a Quick Quote</a>
        <a class="btn btn--ghost" href="#" data-contact-open>Get a Quote</a>
      </div>
    </div>
  </section>

  <section id="services" class="section reveal">
    <div class="container section__grid">
      <div class="section__content">
        <h2 class="animate-in">Our Services</h2>
        <p>
          We provide reliable lawn care to keep your yard clean, consistent, and taken care of.
        </p>

        <a href="/services" class="btn btn--primary">View All Services</a>
      </div>

      <div class="section__media">
        <ul>
          <li>Lawn Mowing</li>
          <li>Edging</li>
          <li>Blowing</li>
          <li>Basic Yard Cleanup</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="about" class="section section--reverse reveal">
    <div class="container section__grid">
      <div class="section__content">
        <h2 class="animate-in">About Us</h2>
        <p>
          Bruce and Cash Vaughan are two hardworking young entrepreneurs based in Lawton, Oklahoma.
        </p>

        <p>
          They take pride in showing up, working hard, and doing the job right—every time.
        </p>

        <a href="/about" class="btn btn--ghost">Learn More About Us</a>
      </div>

      <div class="section__media">
        <img src="/img/Boys.png" alt="Vaughan Boys Outdoor Company owners" class="about-image" />
      </div>
    </div>
  </section>

  <section id="contact" class="section section--contact reveal">
    <div class="container section__grid">
      <div class="section__content">
        <h2 class="animate-in">Get a Quote</h2>
        <p>
          Serving Lawton & surrounding areas. Fill out the form or email us directly at
          <a href="mailto:vaughanoutdoorcompany@gmail.com">vaughanoutdoorcompany@gmail.com</a>.
        </p>
      </div>

      <div class="section__media">
        <form class="contact-form">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required />
          </div>

          <div class="form-group">
            <label for="phone">Phone</label>
            <input type="tel" id="phone" name="phone" required />
          </div>

          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="4"></textarea>
          </div>

          <button type="submit" class="btn btn--primary">Request a Quote</button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 1.25rem 1.5rem;
    text-align: center;
    overflow: hidden;
  }

  .page-hero__video {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .page-hero__video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  .page-hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: rgba(0, 0, 0, 0.5);
    pointer-events: none;
  }

  .page-hero__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 22rem;
    margin-inline: auto;
  }

  .page-hero h1 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.5rem, 5vw + 0.75rem, 2rem);
    font-weight: 700;
    line-height: 1.2;
  }

  .page-hero__tagline {
    margin: 0 0 1.25rem;
    font-size: 1rem;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.88);
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }
</style>