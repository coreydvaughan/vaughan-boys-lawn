<header class="header">
	<div class="header-inner">
		<a href="/" class="logo header-logo">
			<img src="/img/logo.png" alt="Vaughan Boys Lawn Maintenance" width="180" height="60" />
		</a>

		<nav class="nav desktop-nav" aria-label="Primary">
			<a href="/services">Services</a>
			<a href="/about">About</a>
			<a href="#" class="cta" data-contact-open>Get a Quote</a>
		</nav>

		<button type="button" class="menu-toggle" aria-label="Open menu" aria-expanded="false">
			☰
		</button>
	</div>

	<div class="mobile-menu" id="mobile-menu" hidden>
		<button type="button" class="menu-close" aria-label="Close menu">×</button>
		<a href="/services">Services</a>
		<a href="/about">About</a>
		<a href="#" data-contact-open>Get a Quote</a>
		<a href="tel:+12147272404" class="call">Call Now</a>
	</div>
</header>

<style>
	.header {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		z-index: 1000;
	}

	.header.scrolled .header-inner {
		background: rgba(0, 0, 0, 0.88);
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
	}

	.header-inner {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 14px 16px;
		position: relative;
		z-index: 2;
		background: rgba(0, 0, 0, 0.6);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
	}

	.header-logo img {
		height: 48px;
		width: auto;
		display: block;
	}

	.nav {
		display: none;
		align-items: center;
		gap: 0;
	}

	.nav a {
		margin-left: 20px;
		text-decoration: none;
		color: #fff;
		font-size: 14px;
	}

	.nav a:first-child {
		margin-left: 0;
	}

	.cta {
		background: #4caf50;
		color: #000;
		padding: 8px 14px;
		border-radius: 6px;
		font-weight: 600;
	}

	.menu-toggle {
		font-size: 24px;
		line-height: 1;
		min-width: 44px;
		min-height: 44px;
		padding: 0;
		background: none;
		border: none;
		color: #fff;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.mobile-menu {
		display: none;
		flex-direction: column;
		background: #000;
		position: fixed;
		inset: 0;
		z-index: 2000;
		padding: 5rem 20px 24px;
		overflow: auto;
	}

	.mobile-menu.open {
		display: flex;
	}

	.menu-close {
		position: absolute;
		top: 14px;
		right: 10px;
		min-width: 44px;
		min-height: 44px;
		padding: 0;
		font-size: 2rem;
		line-height: 1;
		color: #fff;
		background: none;
		border: none;
		cursor: pointer;
	}

	.mobile-menu a {
		font-size: 22px;
		margin-bottom: 20px;
		color: #fff;
		text-decoration: none;
		min-height: 44px;
		display: flex;
		align-items: center;
	}

	.mobile-menu .call {
		background: #4caf50;
		color: #000;
		padding: 12px;
		text-align: center;
		border-radius: 6px;
		justify-content: center;
		margin-top: auto;
	}

	@media (min-width: 768px) {
		.desktop-nav {
			display: flex;
		}

		.menu-toggle {
			display: none;
		}

		.header-logo img {
			height: 60px;
		}
	}
</style>

<script>
	const header = document.querySelector(".header");
	const toggle = document.querySelector(".menu-toggle");
	const mobileMenu = document.querySelector(".mobile-menu");
	const closeBtn = document.querySelector(".menu-close");

	function setMenuOpen(open) {
		if (!mobileMenu || !toggle) return;
		mobileMenu.classList.toggle("open", open);
		mobileMenu.hidden = !open;
		toggle.setAttribute("aria-expanded", open ? "true" : "false");
		toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
		document.body.style.overflow = open ? "hidden" : "";
		if (open) {
			header?.classList.remove("header--hidden");
		}
	}

	let lastScrollY = window.scrollY;
	let ticking = false;

	function updateScrolled() {
		if (!header) return;
		if (window.scrollY > 50) {
			header.classList.add("scrolled");
		} else {
			header.classList.remove("scrolled");
		}
	}

	window.addEventListener(
		"scroll",
		() => {
			updateScrolled();

			if (!ticking) {
				window.requestAnimationFrame(() => {
					const currentScrollY = window.scrollY;

					if (!header) {
						ticking = false;
						return;
					}

					if (mobileMenu?.classList.contains("open")) {
						lastScrollY = currentScrollY;
						ticking = false;
						return;
					}

					if (Math.abs(currentScrollY - lastScrollY) > 20) {
						if (currentScrollY > lastScrollY && currentScrollY > 100) {
							header.classList.add("header--hidden");
						} else {
							header.classList.remove("header--hidden");
						}

						lastScrollY = currentScrollY;
					}

					ticking = false;
				});

				ticking = true;
			}
		},
		{ passive: true }
	);

	updateScrolled();

	toggle?.addEventListener("click", () => {
		const open = !mobileMenu?.classList.contains("open");
		setMenuOpen(open);
	});

	closeBtn?.addEventListener("click", () => setMenuOpen(false));

	mobileMenu?.querySelectorAll("a").forEach((link) => {
		link.addEventListener("click", () => setMenuOpen(false));
	});

	window.addEventListener("keydown", (e) => {
		if (e.key === "Escape") setMenuOpen(false);
	});
</script>
